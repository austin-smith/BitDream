// Shared build settings layer for repo-wide configurable values.
// Keep environment-specific values out of source-controlled project settings.
SPARKLE_APPCAST_URL = __UNSET__
SPARKLE_PUBLIC_KEY = __UNSET__

// Required local/CI overrides.
// Local development: create Config/BuildSettings.local.xcconfig.
// CI: writes this file before build.
#include "BuildSettings.local.xcconfig"
